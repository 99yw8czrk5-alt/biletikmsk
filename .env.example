TRAVELPAYOUTS_TOKEN=put_your_travelpayouts_token_here
TELEGRAM_BOT_TOKEN=put_your_telegram_bot_token_here
TELEGRAM_CHAT_ID=put_your_telegram_chat_id_here

ORIGIN=MOW
DESTINATION=BKK
CURRENCY=rub
MAX_PRICE=60000
CHECK_INTERVAL_HOURS=6
DAYS_AHEAD=180
LIMIT=100
STATE_PATH=data/seen.json
TELEGRAM_OFFSET_PATH=data/telegram_offset.json
BOT_POLL_SECONDS=1
BOT_RESULTS_LIMIT=5
WEBHOOK_SECRET=change_this_to_a_long_random_string
PORT=8000

# Travelpayouts public price APIs often do not reliably expose baggage.
# strict: alert only when baggage is explicitly detected
# allow_unknown: alert when baggage is detected or the API gives no baggage data
BAGGAGE_MODE=allow_unknown
